{
  "name": "@chordsheets/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "node-pg-migrate up --migration-file-language sql --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --migration-file-language sql --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --migration-file-language sql --migrations-dir src/db/migrations",
    "add-user": "node dist/add-user.js"
  },
  "dependencies": {
    "@chordsheets/shared": "*",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
